{
  "name": "wayfarer",
  "private": true,
  "version": "1.0.0",
  "description": "Smart travel itinerary planner with weather-aware scheduling and offline maps",
  "type": "module",
  "scripts": {
    "icons": "node scripts/make-icons.mjs",
    "predev": "npm run icons",
    "dev": "vite",
    "prebuild": "npm run icons",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "~5.9.0",
    "vite": "^7.0.0",
    "vite-plugin-pwa": "^1.0.0",
    "vitest": "^3.0.0"
  }
}
